# Pinpoint AI — root env file for docker-compose
# Copy to .env and fill in your keys.
# Container-internal URLs are set in docker-compose.yml — these are for secrets only.

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# LLM Providers
ANTHROPIC_API_KEY=""
OPENROUTER_API_KEY=""

# External APIs
KEEPA_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# GCS
GCS_BUCKET_NAME=""
GOOGLE_APPLICATION_CREDENTIALS=""

# Google OAuth
GOOGLE_CLIENT_ID=""

# Sentry
SENTRY_DSN=""
